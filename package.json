{
  "devDependencies": {
    "eslint-plugin-vitest": "^0.5.4",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.2"
  },
  "scripts": {
    "prepare": "husky",
    "check:github": "node .copilot/github-status-check.js",
    "check:github:quick": "node .copilot/github-status-check.js --quick"
  },
  "lint-staged": {
    "*.{ts,tsx,js,json,md}": [
      "prettier --write"
    ],
    "backend/src/**/*.ts": [
      "eslint --fix"
    ],
    "frontend/src/**/*.{ts,tsx}": [
      "eslint --fix"
    ]
  }
}
