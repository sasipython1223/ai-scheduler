@startuml CPM-Engine-Complete-Architecture
!theme cerulean-outline
title AI Scheduler: Complete CPM Engine Architecture (Modules 5.1-5.4)

package "Module 5.1: Schedule Data Models" as M51 {
  class Task {
    +id, name, duration
    +earlyStart, earlyFinish
    +lateStart, lateFinish
    +totalFloat, freeFloat
    +isCritical: boolean
  }
  
  class LogicLink {
    +predecessorId, successorId
    +type: FS|SS|FF|SF
    +lag: number
  }
  
  class ScheduleEngine {
    +tasks: Task[]
    +dependencies: LogicLink[]
    +runCPMAnalysis()
  }
}

package "Module 5.2: CPM Forward Pass" as M52 {
  class ForwardPassEngine {
    +calculateEarlyDates()
    +handleLogicTypes()
    +processTopologically()
  }
  
  class ForwardPassResult {
    +tasksWithEarlyDates: Task[]
    +projectEarlyFinish: Date
  }
}

package "Module 5.3: CPM Backward Pass" as M53 {
  class BackwardPassEngine {
    +calculateLateDates()
    +multiIterationProcessing()
    +handleComplexDependencies()
  }
  
  class FloatCalculator {
    +calculateTotalFloat()
    +calculateFreeFloat()
    +identifyCriticalTasks()
  }
  
  class BackwardPassResult {
    +tasksWithLateDates: Task[]
    +criticalPath: Task[]
    +floatMaps: Map<string, number>
  }
}

package "Module 5.4: Float & Critical Flags" as M54 {
  class EnhancedFloatCalculator {
    +precisionHandling(epsilon: 0.001)
    +batchProcessing()
    +modularCalculations()
  }
  
  class CriticalPathAnalyzer {
    +identifyCriticalTasks()
    +buildCriticalPathSequences()
    +detectMultiplePaths()
  }
  
  class TaskFlagAssigner {
    +assignFloatFlags()
    +assignCriticalFlags()
    +batchFlagAssignment()
  }
  
  class Module54Result {
    +tasksWithFlags: EnhancedTask[]
    +criticalPathAnalysis
    +floatAnalysis
  }
}

package "Integration Layer" as IL {
  class CPMOrchestrator {
    +executeCompleteCPM()
    +coordinateModules()
    +validateResults()
  }
  
  class ResultValidator {
    +validateModuleResults()
    +checkDataConsistency()
    +generateQualityMetrics()
  }
}

package "External Interfaces" as EI {
  interface UIComponents {
    Gantt Charts
    Critical Path View
    Float Analysis
    Task Properties
  }
  
  interface AIServices {
    Schedule Optimization
    Risk Analysis
    Resource Allocation
    Intelligent Suggestions
  }
  
  interface Database {
    Task Persistence
    Project Storage
    Calendar Management
    History Tracking
  }
}

' Module Relationships and Data Flow
M51 ||--|| M52 : "provides data models"
M52 ||--|| M53 : "early dates → late dates"
M53 ||--|| M54 : "basic float → enhanced flags"

ScheduleEngine ||--o{ ForwardPassEngine : "orchestrates"
ScheduleEngine ||--o{ BackwardPassEngine : "orchestrates"

ForwardPassEngine ..> ForwardPassResult : "produces"
BackwardPassEngine ..> BackwardPassResult : "produces"
TaskFlagAssigner ..> Module54Result : "produces"

CPMOrchestrator ||--|| ScheduleEngine : "coordinates"
CPMOrchestrator ||--o{ ResultValidator : "uses"

Module54Result ..> UIComponents : "feeds"
Module54Result ..> AIServices : "feeds"
ScheduleEngine ..> Database : "persists to"

' Module Relationships
M51 ||--|| M52 : "provides data models"
M52 ||--|| M53 : "early dates → late dates"
M53 ||--|| M54 : "basic float → enhanced flags"

ScheduleEngine ||--o{ ForwardPassEngine : "orchestrates"
ScheduleEngine ||--o{ BackwardPassEngine : "orchestrates"
ScheduleEngine ||--o{ Module54Service : "orchestrates"

ForwardPassEngine ..> ForwardPassResult : "produces"
BackwardPassEngine ..> BackwardPassResult : "produces"
Module54Service ..> Module54Result : "produces"

CPMOrchestrator ||--|| ScheduleEngine : "coordinates"
CPMOrchestrator ||--o{ ResultValidator : "uses"

Module54Result ..> UI : "feeds"
Module54Result ..> AI : "feeds"
ScheduleEngine ..> DB : "persists to"

' Enhancement Flow Details
note over M52
  **Forward Pass (Module 5.2)**
  Input: Tasks + Dependencies
  Process: Topological sort → Early dates
  Output: Tasks with earlyStart/earlyFinish
end note

note over M53
  **Backward Pass (Module 5.3)**
  Input: Forward pass result + Project end
  Process: Reverse topological → Late dates + Float
  Output: Tasks with late dates + basic critical flags
end note

note over M54
  **Enhanced Flags (Module 5.4)**
  Input: Backward pass result
  Process: Precision float + Critical analysis + Flag assignment
  Output: Tasks with totalFloat, freeFloat, isCritical
end note

note bottom
  **Complete CPM Engine Pipeline:**
  Module 5.1 (Data Models) → Module 5.2 (Forward Pass) → Module 5.3 (Backward Pass) → Module 5.4 (Enhanced Flags)
  
  **Final Output:** Fully analyzed project schedule with:
  • Accurate early/late dates for all tasks
  • Precise float calculations (total & free)
  • Critical path identification with epsilon precision
  • Enhanced task flags ready for UI and AI integration
  • 100% test coverage and production-ready quality
end note

