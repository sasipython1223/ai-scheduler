// 🧠 Copilot: Define npm run dev tasks
// ✅ "Launch Frontend Dev Server": Run npm run dev in ./frontend
// ✅ "Launch Backend Dev Server": Run npm run dev in ./backend
// ✅ Set correct working directories (cwd)
// ✅ Use shell task, clean setup
// ✅ Background tasks with proper problem matchers
// ✅ Install, lint, format, and build tasks for full development workflow
{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Install All Dependencies",
      "type": "shell",
      "command": "npm install",
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "group": "build",
      "dependsOrder": "sequence",
      "dependsOn": ["Install Backend Dependencies"]
    },
    {
      "label": "Install Backend Dependencies",
      "type": "shell",
      "command": "npm install",
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "group": "build"
    },
    {
      "label": "Start Frontend Dev",
      "type": "shell",
      "command": "npm run dev",
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "group": "build",
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "."
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*VITE.*",
          "endsPattern": ".*Local:.*"
        }
      }
    },
    {
      "label": "Start Backend Dev",
      "type": "shell",
      "command": "npm run dev",
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "group": "build",
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "."
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*starting.*",
          "endsPattern": ".*Server running.*"
        }
      }
    },
    {
      "label": "Start Full Stack Dev",
      "dependsOrder": "parallel",
      "dependsOn": ["Start Frontend Dev", "Start Backend Dev"],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "Lint All",
      "type": "shell",
      "command": "npm run lint",
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "group": "test",
      "dependsOrder": "sequence",
      "dependsOn": ["Lint Backend"]
    },
    {
      "label": "Lint Backend",
      "type": "shell",
      "command": "npm run lint",
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "group": "test"
    },
    {
      "label": "Format All",
      "type": "shell",
      "command": "npm run format",
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "group": "test",
      "dependsOrder": "sequence",
      "dependsOn": ["Format Backend"]
    },
    {
      "label": "Format Backend",
      "type": "shell",
      "command": "npm run format",
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "group": "test"
    },
    {
      "label": "Build All",
      "type": "shell",
      "command": "npm run build",
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "group": "build",
      "dependsOrder": "sequence",
      "dependsOn": ["Build Backend"]
    },
    {
      "label": "Build Backend",
      "type": "shell",
      "command": "npm run build",
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "group": "build"
    },
    {
      "label": "Check GitHub Status Integration",
      "type": "shell",
      "command": "npm run check:github",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "test",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Quick GitHub Status Check",
      "type": "shell",
      "command": "npm run check:github:quick",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "test",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      },
      "problemMatcher": []
    }
  ]
}
