#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

echo "🛡️ Checking for protected file modifications..."

# Define frozen file patterns (critical working modules)
FROZEN_PATTERNS="^(backend/src/modules/module5/|backend/src/modules/module7/7\.4-resilience-framework/|frontend/src/components/constraint-feedback\.tsx)"

# Check for changes to frozen files
CHANGED_FILES=$(git diff --cached --name-only)
if [ -n "$CHANGED_FILES" ]; then
  FROZEN_CHANGES=$(echo "$CHANGED_FILES" | grep -E "$FROZEN_PATTERNS" 2>/dev/null || true)
  
  if [ -n "$FROZEN_CHANGES" ]; then
    echo "❌ PROTECTED FILES MODIFIED:"
    echo "$FROZEN_CHANGES"
    echo ""
    echo "🔒 These files are protected because they contain working, tested code:"
    echo "   • Module 5: Complete CPM engine (all tests passing)"
    echo "   • Module 7.4: Risk Manager (7/7 tests passing)"
    echo "   • constraint-feedback.tsx: Working UI component"
    echo ""
    echo "If changes are intentional:"
    echo "1. Create feature branch: git checkout -b fix/update-protected-file"
    echo "2. Get team review before merging"
    echo "3. Or temporarily bypass: git commit --no-verify"
    echo ""
    exit 1
  fi
fi

echo "✅ No protected files modified"

# Run quick validation
if command -v npm >/dev/null 2>&1; then
  echo "🧪 Running quick validation..."
  # Only run lint if package.json has lint script
  if npm run lint --silent 2>/dev/null; then
    echo "✅ Lint passed"
  else
    echo "⚠️  Lint check skipped or failed"
  fi
else
  echo "⚠️  npm not found, skipping validation"
fi
