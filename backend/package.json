{
  "name": "ai-scheduler-backend",
  "version": "7.3.1",
  "description": "AI-powered scheduling system backend with Module 7.x regression testing",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:reg": "jest --runInBand src/modules/module7/__regression__",
    "test:perf": "jest --runInBand src/modules/module7/__regression__/perf",
    "test:e2e": "jest --runInBand src/modules/module7/__regression__/e2e",
    "test:ci": "jest --runInBand src/modules/module7/__regression__/ci && jest --runInBand src/modules/module7/__regression__/perf/perf.snapshot.test.ts",
    "test:module7": "npm run test:reg && npm run test:perf",
    "bench:7x": "node scripts/bench-simple.mjs",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix"
  },
  "keywords": [
    "scheduling",
    "ai",
    "optimization",
    "resource-management",
    "typescript"
  ],
  "author": "AI Scheduler Team",
  "license": "MIT",
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "helmet": "^7.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.13",
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.5",
    "@types/node": "^20.19.10",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.50.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.1",
    "ts-node": "^10.9.1",
    "typescript": "^5.9.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  }
}
